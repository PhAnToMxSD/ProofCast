# ── Solana devnet ────────────────────────────────────────────────────────────
# Path to a Solana devnet keypair (JSON array of the 64-byte secret key).
# If the file does not exist, scripts/01-auth.ts will generate one here.
SOLANA_KEYPAIR_PATH=./.keys/devnet.json

# Devnet RPC. Override only if you have a private endpoint (public one is rate-limited).
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── TxLINE (earned in Phase 2 — do NOT fill these in by hand) ─────────────────
# Populated by scripts/01-auth.ts and cached to cache/auth.json.

# ── OpenRouter (Phase 5) ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── ElevenLabs (Phase 6 — quota-critical, 10k chars/month) ────────────────────
ELEVENLABS_API_KEY=
